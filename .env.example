# --- LLM (nhóm dùng Gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here
DEFAULT_PROVIDER=google
DEFAULT_MODEL=gemini-2.5-flash
# Khi gặp 429 ResourceExhausted (free tier): số lần thử lại sau khi chờ (mặc định 5)
GEMINI_MAX_RETRIES=5

# OPENAI (nếu đổi provider)
OPENAI_API_KEY=your_openai_api_key_here

# LOCAL LLM (GGUF via llama-cpp)
LOCAL_MODEL_PATH=./models/Phi-3-mini-4k-instruct-q4.gguf

# --- Travel APIs (API thật) ---
# OpenWeather: https://home.openweathermap.org/api_keys — key thường kích hoạt sau 10 phút–2 giờ; không thêm ngoặc kép
OPENWEATHER_API_KEY=your_openweather_key_here
DUFFEL_ACCESS_TOKEN=your_duffel_access_token
# Backward-compatible alias (neu ban dang dung ten cu):
# DUFFEL_API_TOKEN=your_duffel_access_token
# Optional, default v2
DUFFEL_API_VERSION=v2
# Flight search mode: crawl_first (default), crawl, api_first, api
FLIGHT_SEARCH_METHOD=crawl_first

# Bật 1 = khi THIẾU key OpenWeather/Duffel, tool trả dữ liệu mẫu (chỉ học/demo, không phải giá thật)
DEMO_TRAVEL_APIS=0

# --- Agent ---
AGENT_MAX_STEPS=8
LOG_LEVEL=INFO
